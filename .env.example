DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=hyreme
DB_TYPE=sqlite # sqlite면 로컬 파일 DB로 동작, 나머지 DB 설정은 무시됨
DB_PATH=./hyreme.db # sqlite 파일 위치. 비워도 기본값 사용

# JWT 설정
SECRET_KEY=your_secret_key_here_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS 설정 (쉼표로 여러 origin 지정 가능)
CORS_ORIGINS=http://localhost:3000
